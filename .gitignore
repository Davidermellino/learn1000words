# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# The Flutter SDK itself is installed inside this folder (it is on PATH from
# here) — it is a tool, not part of the app source.
/flutter/

# Supabase / OAuth credentials (passed via --dart-define or
# --dart-define-from-file — see SUPABASE_SETUP.md). Never commit them.
.env
*.env
env.json

# Android release signing — NEVER commit the keystore or its passwords.
# The keystore is the permanent, unrecoverable upload identity for Play.
**/key.properties
*.jks
*.keystore

# Node tooling for the graphics/image scripts (sharp, supabase image libs).
# The package.json / package-lock.json manifest is committed; the installed
# dependency tree is not.
/node_modules/

# Supabase CLI local link state (project ref, versions) — machine-local, not source.
supabase/.temp/
