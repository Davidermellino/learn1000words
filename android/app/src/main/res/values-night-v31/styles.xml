<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash in dark mode. Same as values-v31 but with the dark
         parent theme; ermine_splash_bg resolves to ink via values-night. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@color/ermine_splash_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/splash_icon</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
