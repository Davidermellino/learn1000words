<?xml version="1.0" encoding="utf-8"?>
<!-- Native launch splash (Android < 12). The ermine, centred on the brand
     splash background. On Android 12+ the SplashScreen API takes over — see
     values-v31 / values-night-v31. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/ermine_splash_bg" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/splash_icon" />
    </item>
</layer-list>
